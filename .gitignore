# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit secrets)
.env
.env.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python agent
agent/__pycache__/
agent/**/__pycache__/
agent/*.pyc
agent/.venv/
agent/venv/
agent/config.local.json
agent/config.json
agent/*.log
agent/state.json

# local probes / intermediate dumps (throwaway; not needed by the app)
agent/probe_*.py
agent/save_dump.json
agent/steam_items.json
agent/steam_search.json

# extracted game data (intermediate; regenerated by agent/*.py — the committed
# lib/game/*.generated.json catalogs are what the app actually uses)
agent/extracted/

# local save snapshots / decrypted dumps (may contain personal data)
*.es3
*_plain.json
player_pretty.json
